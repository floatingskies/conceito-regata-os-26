[General]
ColorScheme=RegataOSDark
Name=RegataOS Dark
shadeSortColumn=true

[KDE]
contrast=4

# ── Gerenciador de janelas ────────────────────────────────────────────────────
# activeBackground  = --bg-sidebar #0e1018 → 14,16,24
# activeForeground  = --text #e8eaf0       → 232,234,240
# inactiveBackground = um step ainda mais escuro
# inactiveForeground = --text-muted #8892a4 → 136,146,164
[WM]
activeBackground=14,16,24
activeBlend=232,234,240
activeForeground=232,234,240
inactiveBackground=10,12,20
inactiveBlend=136,146,164
inactiveForeground=136,146,164
